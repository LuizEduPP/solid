    "start": "NODE_ENV=production node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "node --import tsx --test src/server/agent/agent.test.ts"
  },
