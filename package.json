    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "eventsource-parser": "^3.1.0",
    "file-saver": "^2.0.5",
    "github-markdown-css": "^5.9.0",
    "hono": "^4.11.4",
    "i18next": "^26.3.4",
    "lucide-react": "^1.23.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "openai": "^6.16.0",
