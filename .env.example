# LLM provider (OpenAI, Ollama, vLLM, etc.)
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEARCH_MODEL=gpt-4o-mini

# Agent defaults
DEEPSEARCH_TARGET_SCORE=90.0
DEEPSEARCH_MAX_ITERATIONS=10
DEEPSEARCH_MIN_SCORE=0.01
DEEPSEARCH_RESULTS_PER_QUERY=5

# Server
DEEPSEARCH_HOST=0.0.0.0
DEEPSEARCH_PORT=8787
